# Modo do site
# - catalog (padrão): institucional/mostruário, sem carrinho, CTA = orçamento
# - ecommerce: loja com carrinho + checkout
NEXT_PUBLIC_MODE=catalog

# === Envio de e-mail dos orçamentos ===
# Cadastre em https://resend.com (free tier: 100/dia · 3000/mês),
# crie uma API key e cole abaixo.
RESEND_API_KEY=

# Para onde os orçamentos serão enviados (caixa da Incomolas).
EMAIL_TO=incomolas@gmail.com

# Remetente. Sem domínio próprio verificado, use o sandbox da Resend:
#   onboarding@resend.dev
# Quando tiver domínio (ex: incomolas.com.br) verificado no Resend, troque para:
#   "Incomolas <orcamento@incomolas.com.br>"
EMAIL_FROM="Incomolas Orçamentos <onboarding@resend.dev>"
